#:kivy 2.1.0
<BioScreen>:
    FloatLayout:
        Label:
            text: "Tell a little bit about yourself first"
            size_hint: 1, .1
            pos_hint: {"top": 1, "center_x": 0.5}
            font_size: "20sp"         

        TextInput:
            id: name_input
            hint_text: "Enter your name"
            size_hint: .8, .1
            pos_hint: {"center_x": 0.5, "top": 0.85}
            multiline: False

        TextInput:
            id: username_input
            hint_text: 'Enter preferred lunch location'
            size_hint: .8, .1
            pos_hint: {"center_x": 0.5, "top": 0.72}
            multiline: False

        TextInput:
            id: username_input
            hint_text: "Enter preferred lunch time"
            size_hint: .8, .15
            pos_hint: {"center_x": 0.5, "top": 0.72}
            multiline: False
        Label:
            text: ''
            color: 1, 0, 0, 1

        Button:
            text: 'Submit'
            on_press: app.validate_inputs(root)
