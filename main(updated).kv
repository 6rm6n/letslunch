#:kivy 2.1.0
#:include kv/homescreen.kv
#:include kv/settingsscreen.kv
#:include kv/signupscreen.kv
#:include kv/chatscreen.kv
#:include kv/addfriendscreen.kv
#:include kv/bioscreen.kv
#:include kv/bioscreentwo.kv
#:include kv/centralpage.kv

GridLayout: # root widget
    cols: 1
    ScreenManager:
        id: screen_manager
        HomeScreen:
            name: "home_screen"
            id: home_screen
         ChatScreen:
            name: "chat_screen"
            id: chat_screen
        AddFriendScreen:
            name: "add_friend_screen"
            id: add_friend_screen
        SignupScreen:
            name: "signup_screen"
            id: signup_screen
        SettingsScreen:
            name: "settings_screen"
            id: settings_screen
        BioScreen:
            name: "bio_screen"
            id: bio_screen
        BioScreen:
            name: "bio_screen_two"
            id: bio_screen_two
        CentralPage:
            name: "central_page"
            id: central_page