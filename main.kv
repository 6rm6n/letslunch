GridLayout: # root widget
    cols: 1
    ScreenManager:
        id: screen_manager
        HomeScreen:
            name: "home_screen"
            id: home_screen
        ChatScreen:
            name: "chat_screen"
            id: chat_screen
        AddFriendScreen:
            name: "add_friend_screen"
            id: add_friend_screen
        SignupScreen:
            name: "signup_screen"
            id: signup_screen
        SettingsScreen:
            name: "settings_screen"
            id: settings_screen
        FirstBioScreen:
            name: "first_bio_screen"
            id: first_bio_screen
        SecondBioScreen:
            name: "second_bio_screen"
            id: second_bio_screen
        BioValidation:
            name: "bio_validation_screen"
            id: bio_validation
        ThirdBioScreen:
            name: "third_bio_screen"
            id: third_bio_screen
        CentralPage:
            name: "central_page"
            id: central_page
