# name
# pronouns
# major

<Signup2Screen>:
    FloatLayout:
        Label:
            text: "Please share some basic information!"
            size_hint: 1, .1
            pos_hint: {"top": 1, "center_x": 0.5}
            font_size: "20sp"

        TextInput:
            id: name_input
            hint_text: "Enter your name"
            size_hint: .8, .1
            pos_hint: {"center_x": 0.5, "top": 0.85}
            multiline: False

        TextInput:
            id: pronouns_input
            hint_text: "Enter your preferred pronouns"
            size_hint: .8, .1
            pos_hint: {"center_x": 0.5, "top": 0.72}
            multiline: False

        TextInput:
            id: major_input
            hint_text: "Enter your major"
            size_hint: .8, .1
            pos_hint: {"center_x": 0.5, "top": 0.59}
            multiline: False

        Button:
            text: "Continue"
            size_hint: .8, .1
            pos_hint: {"center_x": 0.5, "top": 0.46}
            on_release:
                #change screen to bio input
                #call initBio
                #put inside database somehow
                #call Myra's validation function
                app.capture_signup2(name_input.text, pronouns_input.text, major_input.text)
                app.change_screen("signup_3_screen")

        Label:
            id: message_label
            text: ""
            size_hint: 1, .1
            pos_hint: {"top": 0.35, "center_x": 0.5}
            color: 1, 0, 0, 1
