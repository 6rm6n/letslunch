#:import utils kivy.utils

<HomeScreen>:
    FloatLayout: # specifying sizes so needs float
        canvas:
            Color: 
                rgb: utils.get_color_from_hex("#39B3F2")
            Rectangle:
                size: self.size
                pos: self.pos
            Color:
                rgb: utils.get_color_from_hex("#A2B3F2")
            Rectangle:
                size: self.width * 0.75, self.height * 0.6  # Adjust these values for desired size
                pos: self.width * 0.5 - (self.width * 0.75 * 0.5), self.height * 0.5 - (self.height * 0.6 * 0.5)

        Button:
            size_hint: 0.05, 0.05
            pos_hint: {'center_x': 0.09375, 'center_y': 0.45}
            background_normal: 'love.png'
            on_press: root.doesLike(self)

        Button:
            size_hint: 0.05, 0.05
            pos_hint: {'center_x': 0.281, 'center_y': 0.45}
            background_normal: 'no.png'
            on_press: root.doesNot(self)

        GridLayout:
            rows: 1
            size_hint: None, None
            #size_hint: 1, .1
            pos_hint: {"top": .99, "right": .99}
            ImageButton:
                source: "icons/magnify8.png"
                on_release:
                    app.change_screen("add_friend_screen")
                    print('Find friend')
#---
        GridLayout:
            # Put two weather icons and avatar icon
            rows: 1
            pos_hint: {"top": .9, "left": 1}
            size_hint: 1, .1
            # put two weather icons and avatar icon
            Image:
                source: "icons/burger8_1.png"
            ImageButton:
                source: "icons/pizza8.png"
                on_press: app.change_screen("signup_screen")
            Image:
                source: "icons/burger8_2.png"


        Label: 
            # Streak label
            pos_hint: {"top": .7, "left": 1}
            size_hint: 1, .1
            text: "Let's Get Lunch Together!"
            id: streak_label
        GridLayout:
            # Banner grid
            cols: 1
            pos_hint: {"top":.6, "left": 1}
            size_hint: 1, .4
        GridLayout:
            # Add 3 Menu buttons here
            rows: 1
            pos_hint: {"top": .2, "left": 1}
            size_hint: 1, .2
            ImageButton: # chat button
                source: "icons/chat8.png"
                on_release:
                    print("RELEASED CHAT BUTTON")
                    app.change_screen("chat_screen")

            ImageButton:
                source: "icons/burger8_1.png"
                on_press:
                    self.source = "icons/burger8_2.png"
                on_release:
                    self.source = "icons/burger8_1.png"
                    print("RELEASED BURGER BUTTON")
                    app.change_screen("home_screen")

            ImageButton:
                source: "icons/settings8.png"
                on_release:
                    print("RELEASED SETTINGS BUTTON")
                    app.change_screen("settings_screen")
