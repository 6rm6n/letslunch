# about

<Signup3Screen>:
    FloatLayout:
        Label:
            text: "Tell a little bit about yourself"
            size_hint: 1, .1
            pos_hint: {"top": 1, "center_x": 0.5}
            font_size: "20sp"

        TextInput:
            id: about_input
            hint_text: "Tell a little bit about yourself"
            size_hint: .8, .3
            pos_hint: {"center_x": 0.5, "top": 0.85}
            multiline: False


        Button:
            text: "Continue"
            size_hint: .8, .1
            pos_hint: {"center_x": 0.5, "top": 0.46}
            on_release: 
                #change screen to bio input
                #call initBio
                #put inside database somehow
                app.change_screen("signup_4_screen")

        Label:
            id: message_label
            text: ""
            size_hint: 1, .1
            pos_hint: {"top": 0.35, "center_x": 0.5}
            color: 1, 0, 0, 1
