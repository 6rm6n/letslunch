# where do you have lunch?

<Signup4Screen>:
    BoxLayout:
        orientation: 'vertical'
        padding: 10
        spacing: 10

        Label:
            id: error_label
            text: ''
            color: 1, 0, 0, 1

        Button:
            text: 'Noon'
            font_size: 40
            on_press: app.pressed_time(self)
            background_color: 1, 0, 0, 1
            

        Button:
            text: '11:30'
            font_size: 40
            on_press: app.pressed_time(self)
            background_color: 1, 0, 0, 1

        Button:
            text: '12:30'
            font_size: 40
            on_press: app.pressed_time(self)
            background_color: 1, 0, 0, 1

        Button:
            text: 'Southside'
            font_size: 40
            on_press: app.pressed_location(self)
            background_color: 1, 0, 0, 1

        Button:
            text: 'Ikes'
            font_size: 40
            on_press: app.pressed_location(self)
            background_color: 1, 0, 0, 1

        Button:
            text: 'Globe'
            font_size: 40
            on_press: app.pressed_location(self)
            background_color: 1, 0, 0, 1

        Button:
            text: 'Submit'
            on_release: app.change_screen("home_screen")
            background_color: 1, 0, 0, 1
