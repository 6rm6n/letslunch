#Will be called after second bio screen
<ThirdBioScreen>:
    FloatLayout:
        Label:
            text: "When and where do you usually have lunch?"
            size_hint: 1, .1
            pos_hint: {"top": 1, "center_x": 0.5}
            font_size: "20sp"

        TextInput:
            id: email_input
            hint_text: "When do you usually have lunch"
            size_hint: .8, .15
            pos_hint: {"center_x": 0.5, "top": 0.85}
            multiline: False

        TextInput:
            id: username_input
            hint_text: "Where do you usually have lunch"
            size_hint: .8, .15
            pos_hint: {"center_x": 0.5, "top": 0.72}
            multiline: False

        Button:
            text: "Continue"
            size_hint: .8, .1
            pos_hint: {"center_x": 0.5, "top": 0.46}
            on_release:
                #change screen to bio input
                #call initBio
                #put inside database somehow
                app.change_screen("bio_validation_screen")
                
        Label:
            id: message_label
            text: ""
            size_hint: 1, .1
            pos_hint: {"top": 0.35, "center_x": 0.5}
            color: 1, 0, 0, 1
