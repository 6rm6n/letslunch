# username
# pw

<Signup1Screen>:
    FloatLayout:
        Label:
            text: "Let's create an account!"
            size_hint: 1, .1
            pos_hint: {"top": 1, "center_x": 0.5}
            font_size: "20sp"

        TextInput:
            id: email_input
            hint_text: "Enter your GMU email"
            size_hint: .8, .1
            pos_hint: {"center_x": 0.5, "top": 0.85}
            multiline: False

        TextInput:
            id: username_input
            hint_text: "Create a Username"
            size_hint: .8, .1
            pos_hint: {"center_x": 0.5, "top": 0.72}
            multiline: False

        TextInput:
            id: password_input
            hint_text: "Create a Password"
            password: True
            size_hint: .8, .1
            pos_hint: {"center_x": 0.5, "top": 0.59}
            multiline: False

        Button:
            text: "Continue"
            size_hint: .8, .1
            pos_hint: {"center_x": 0.5, "top": 0.46}
            on_release:
                #change screen to bio input
                #call initBio
                #put inside database somehow
                #root.sign_up(email_input.text, username_input.text, password_input.text)
                app.change_screen("signup_2_screen")

        Label:
            id: message_label
            text: ""
            size_hint: 1, .1
            pos_hint: {"top": 0.35, "center_x": 0.5}
            color: 1, 0, 0, 1
